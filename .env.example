# App
# Switch to production for real deployments.
APP_ENV=development
APP_BASE_URL=http://localhost:8080
LOG_LEVEL=debug
ENCRYPTION_MASTER_KEY=change-me-32-bytes-minimum
BOOTSTRAP_IMAP_USERNAME=imapped@example.com
BOOTSTRAP_IMAP_PASSWORD=change-me-for-dev

# IMAP listener
IMAP_PLAINTEXT_BIND=0.0.0.0:1143
IMAP_TLS_BIND=0.0.0.0:1993
IMAP_TLS_CERT_PATH=/certs/imap.crt
IMAP_TLS_KEY_PATH=/certs/imap.key

# HTTP metrics/admin
HTTP_BIND=0.0.0.0:8080
METRICS_BIND=0.0.0.0:9090

# PostgreSQL
DATABASE_URL=postgres://imap_cache:imap_cache_password@postgres:5432/imap_cache

# Redis
REDIS_URL=redis://redis:6379

# S3-compatible object storage (Cloudflare R2, AWS S3, or compatible)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=imap-cache
R2_ACCESS_KEY_ID=<r2-access-key>
R2_SECRET_ACCESS_KEY=<r2-secret-key>
R2_REGION=auto

# Local object store fallback for development and tests only
OBJECT_STORE_PATH=./data/blob

# Tantivy search
SEARCH_INDEX_PATH=./data/search

# Defaults / safety limits
MAX_LITERAL_SIZE_BYTES=52428800
MAX_MESSAGE_SIZE_BYTES=104857600
DEFAULT_ACCOUNT_QUOTA_BYTES=10737418240
SYNC_CONCURRENCY=4
UPSTREAM_CONNECTION_LIMIT_PER_ACCOUNT=2
LOGIN_RATE_LIMIT_FAILURES=5
LOGIN_RATE_LIMIT_LOCKOUT_SECONDS=60
PERIODIC_SYNC_INTERVAL_SECONDS=3600
